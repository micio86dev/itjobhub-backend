# Dedicated test database — loaded automatically by `bun test` (NODE_ENV=test).
# Tests run destructive deleteMany({}) cleanups, so they MUST target an
# isolated DB. tests/preload.ts additionally enforces a *_test name and aborts
# otherwise; this file just makes the local default explicit.
DATABASE_URL="mongodb://127.0.0.1:27017/itjobhub_test?replicaSet=rs0&w=1&journal=true"
JWT_SECRET="test_secret"
